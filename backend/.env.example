# ==================== Talk2Code 配置文件 ====================
# 复制此文件为 .env 并填写实际值

# ==================== 必需配置 ====================

# 阿里云百炼大模型 API Key（必需）
# 获取方式：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your_api_key_here

# ==================== 安全配置 ====================

# JWT 密钥（生产环境必须修改！）
# 建议使用 openssl rand -hex 32 生成
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_USE_RANDOM_STRING

# ==================== 数据库配置 ====================

# 数据库文件名（默认：vcd.db）
DATABASE_NAME=vcd.db

# ==================== LLM 配置 ====================

# 模型选择（可选）
# 可选值：qwen-plus, qwen-turbo, qwen-max, qwen-max-longcontext
DASHSCOPE_MODEL=qwen-plus

# LLM 调用参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000
LLM_TIMEOUT=60
LLM_MAX_RETRIES=2

# ==================== 应用配置 ====================

# 应用端口
APP_PORT=5001

# 调试模式（生产环境必须为 false）
APP_DEBUG=false

# 日志级别
# 可选值：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== 安全参数 ====================

# 密码最小长度
PASSWORD_MIN_LENGTH=6

# 用户名最小长度
USERNAME_MIN_LENGTH=3

# ==================== 任务队列配置 ====================

# 最大并发任务数
TASK_QUEUE_MAX_WORKERS=3